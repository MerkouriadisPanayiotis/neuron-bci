# NEURON — Environment Variables
# Copy this file to .env and fill in your API keys.

# Claude API (only needed if claude.backend = "api" in config.yaml)
# Get from: https://console.anthropic.com/
# Not needed if using backend = "agent-sdk" (uses Claude Code auth)
ANTHROPIC_API_KEY=

# Google Gemini (for AI image generation via Nano Banana 2)
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ElevenLabs Music (for AI music generation)
# Get from: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
